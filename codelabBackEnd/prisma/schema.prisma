generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Rol {
  id          BigInt       @id @default(autoincrement())
  nombre      String       @unique @db.VarChar(100)
  descripcion String?      @db.VarChar(255)
  disponible  Boolean      @default(true)
  createdAt   DateTime?    @map("created_at")
  rolPermisos RolPermiso[]
  usuarios    Usuario[]
}

model Permiso {
  id          BigInt           @id @default(autoincrement())
  nombre      String           @unique @db.VarChar(100)
  descripcion String?          @db.VarChar(255)
  disponible  Boolean          @default(true)
  createdAt   DateTime?        @map("created_at")
  categoriaId BigInt
  categoria   CategoriaPermiso @relation(fields: [categoriaId], references: [id])
  rolPermisos RolPermiso[]
}

model RolPermiso {
  rolId     BigInt
  permisoId BigInt
  permiso   Permiso @relation(fields: [permisoId], references: [id])
  rol       Rol     @relation(fields: [rolId], references: [id])

  @@id([rolId, permisoId])
}

model CategoriaPermiso {
  id              BigInt    @id @default(autoincrement())
  nombreCategoria String    @db.VarChar(150)
  disponible      Boolean   @default(true)
  permisos        Permiso[]
}

model Sucursal {
  id                    BigInt                 @id @default(autoincrement())
  nombre                String                 @db.VarChar(150)
  direccion             String?                @db.VarChar(255)
  telefono              String?                @db.VarChar(50)
  gerente               String?                @db.VarChar(150)
  activa                Boolean                @default(true)
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime
  usuarios              Usuario[]
  movimientoInventarios MovimientoInventario[]
}

model Usuario {
  id                    BigInt                 @id @default(autoincrement())
  nombreCompleto        String                 @map("nombre_completo") @db.VarChar(150)
  correo                String                 @unique @db.VarChar(150)
  password              String                 @db.VarChar(255)
  estado                EstadoUsuario          @default(activo)
  createdAt             DateTime?              @map("created_at")
  updatedAt             DateTime?              @map("updated_at")
  sucursalId            BigInt?
  rolId                 BigInt?
  eliminado             Boolean                @default(false)
  usuario               String                 @unique @db.VarChar(100)
  rol                   Rol?                   @relation(fields: [rolId], references: [id])
  sucursal              Sucursal?              @relation(fields: [sucursalId], references: [id])
  movimientoInventarios MovimientoInventario[]
}

model Categoria {
  id          BigInt     @id @default(autoincrement())
  nombre      String     @db.VarChar(150)
  descripcion String?    @db.VarChar(255)
  disponible  Boolean    @default(true)
  productos   Producto[]
}

model Proveedor {
  id                    BigInt                 @id @default(autoincrement())
  nombre                String                 @db.VarChar(150)
  telefono              String?                @db.VarChar(50)
  correo                String?                @db.VarChar(150)
  direccion             String?                @db.VarChar(255)
  disponible            Boolean                @default(true)
  Producto              Producto[]             @relation("ProductoProveedor")
  movimientoInventarios MovimientoInventario[]
}

model Producto {
  id           BigInt                 @id @default(autoincrement())
  nombre       String                 @db.VarChar(150)
  sku          String                 @unique @db.VarChar(100)
  costo        Decimal                @db.Decimal(10, 2)
  precioVenta  Decimal                @map("precio_venta") @db.Decimal(10, 2)
  unidadMedida String?                @map("unidad_medida") @db.VarChar(50)
  estado       EstadoProducto         @default(activo)
  createdAt    DateTime?              @map("created_at")
  updatedAt    DateTime?              @map("updated_at")
  categoriaId  BigInt?
  imagenUrl    String?                @map("imagen_url") @db.VarChar(255)
  imagenPath   String?                @map("imagen_path") @db.VarChar(255)
  detalles     DetalleVenta[]
  inventarios  Inventario[]
  movimientos  MovimientoInventario[]
  categoria    Categoria?             @relation(fields: [categoriaId], references: [id])
  Proveedor    Proveedor[]            @relation("ProductoProveedor")
}

model Inventario {
  id          BigInt   @id @default(autoincrement())
  stockActual Int      @default(0) @map("stock_actual")
  productoId  BigInt
  sucursalId  BigInt
  producto    Producto @relation(fields: [productoId], references: [id])

  @@unique([productoId, sucursalId])
}

model MovimientoInventario {
  id                      BigInt                    @id @default(autoincrement())
  tipo                    TipoMovimientoInventario
  subtipoEntrada          SubtipoEntradaInventario? @map("subtipo_entrada")
  motivoSalida            MotivoSalidaInventario?   @map("motivo_salida")
  detalleMotivo           String?                   @map("detalle_motivo") @db.VarChar(255)
  observaciones           String?                   @db.Text
  cantidad                Int
  stockResultante         Int                       @map("stock_resultante")
  fechaMovimiento         DateTime                  @map("fecha_movimiento")
  estado                  String                    @default("completado") @db.VarChar(30)
  referenciaTipo          String?                   @map("referencia_tipo") @db.VarChar(50)
  referenciaId            BigInt?                   @map("referencia_id")
  createdAt               DateTime                  @default(now()) @map("created_at")
  productoId              BigInt
  sucursalId              BigInt
  usuarioId               BigInt?
  proveedorId             BigInt?
  metodoValuacionAplicado MetodoValuacion?          @map("metodo_valuacion_aplicado")
  costoUnitario           Decimal?                  @map("costo_unitario") @db.Decimal(10, 2)
  costoTotal              Decimal?                  @map("costo_total") @db.Decimal(10, 2)

  producto  Producto   @relation(fields: [productoId], references: [id])
  sucursal  Sucursal   @relation(fields: [sucursalId], references: [id])
  usuario   Usuario?   @relation(fields: [usuarioId], references: [id])
  proveedor Proveedor? @relation(fields: [proveedorId], references: [id])

  @@index([productoId])
  @@index([sucursalId])
  @@index([usuarioId])
  @@index([proveedorId])
  @@index([fechaMovimiento])
}

model TipoCliente {
  id       BigInt    @id @default(autoincrement())
  nombre   String    @db.VarChar(100)
  clientes Cliente[]
}

model Cliente {
  id             BigInt       @id @default(autoincrement())
  nombreCompleto String?      @map("nombre_completo") @db.VarChar(150)
  identificacion String?      @unique @db.VarChar(50)
  telefono       String?      @db.VarChar(50)
  correo         String?      @db.VarChar(150)
  direccion      String?      @db.VarChar(255)
  tipoClienteId  BigInt?
  tipoCliente    TipoCliente? @relation(fields: [tipoClienteId], references: [id])
}

model TipoDocumento {
  id                        BigInt                         @id @default(autoincrement())
  numero                    Int                            @unique
  nombre                    String                         @unique @db.VarChar(150)
  disponible                Boolean                        @default(true)
  establecimientoDocumentos EstablecimientoTipoDocumento[]

  @@map("TipoDocumento")
}

model RangoEmision {
  id     BigInt @id @default(autoincrement())
  inicio Int
  fin    Int

  @@map("RangoEmision")
}

model Cai {
  id          BigInt    @id @default(autoincrement())
  codigo      String    @unique @db.VarChar(100)
  fechaInicio DateTime? @map("fecha_inicio")
  fechaFin    DateTime? @map("fecha_fin")
  activo      Boolean

  @@map("Cai")
}

model NumeroFactura {
  id                BigInt  @id @default(autoincrement())
  numeroFormateado  String? @unique @map("numero_formateado") @db.VarChar(50)
  correlativo       Int
  usado             Boolean @default(false)
  tipoDocumentoId   BigInt
  establecimientoId BigInt
  puntoEmisionId    BigInt
  caiId             BigInt?

  @@unique([tipoDocumentoId, establecimientoId, puntoEmisionId, correlativo])
}

model Venta {
  id         BigInt      @id @default(autoincrement())
  total      Decimal     @db.Decimal(10, 2)
  estado     EstadoVenta
  createdAt  DateTime?   @map("created_at")
  clienteId  BigInt?
  usuarioId  BigInt?
  sucursalId BigInt?
}

model DetalleVenta {
  id             BigInt   @id @default(autoincrement())
  cantidad       Int
  precioUnitario Decimal  @map("precio_unitario") @db.Decimal(10, 2)
  subtotal       Decimal  @db.Decimal(10, 2)
  ventaId        BigInt
  productoId     BigInt
  producto       Producto @relation(fields: [productoId], references: [id])
}

model ConfiguracionContable {
  id              BigInt          @id @default(autoincrement())
  metodoValuacion MetodoValuacion @map("metodo_valuacion")
  monedaFuncional String          @map("moneda_funcional") @db.VarChar(10)
}

model Establecimiento {
  id                        BigInt                         @id @default(autoincrement())
  numero                    Int
  tipoDocumentoId           BigInt
  sucursalId                BigInt
  establecimientoDocumentos EstablecimientoTipoDocumento[]

  @@unique([numero, tipoDocumentoId])
}

model Factura {
  id              BigInt   @id @default(autoincrement())
  subtotal        Decimal  @db.Decimal(10, 2)
  impuesto        Decimal  @db.Decimal(10, 2)
  total           Decimal  @db.Decimal(10, 2)
  fecha_emision   DateTime
  numeroFacturaId BigInt   @unique
  ventaId         BigInt?  @unique
  clienteId       BigInt?
  usuarioId       BigInt?
  sucursalId      BigInt?
}

model PuntoEmision {
  id                BigInt  @id @default(autoincrement())
  numero            Int
  tipoDocumentoId   BigInt
  establecimientoId BigInt
  rangoEmisionId    BigInt?

  @@unique([numero, establecimientoId])
}

model EstablecimientoTipoDocumento {
  id                BigInt          @id @default(autoincrement())
  establecimientoId BigInt          @map("id_establecimiento")
  tipoDocumentoId   BigInt          @map("id_tipo_documento")
  disponible        Boolean         @default(true)
  establecimiento   Establecimiento @relation(fields: [establecimientoId], references: [id])
  tipoDocumento     TipoDocumento   @relation(fields: [tipoDocumentoId], references: [id])

  @@unique([establecimientoId, tipoDocumentoId])
  @@map("EstablecimientoTipoDocumento")
}

model DiccNaturalezaCuenta {
  id                  BigInt               @id @default(autoincrement()) @map("id_naturaleza")
  uuidNaturaleza      String               @unique @map("uuid_naturaleza") @db.VarChar(64)
  nombre              String               @db.VarChar(50)
  disponible          Boolean              @default(true)

  elementosContables  ElementoContable[]
  subCuentasContables SubCuentaContable[]

  @@map("DICC_NATURALEZA_CUENTA")
}

model ElementoContable {
  id                           BigInt                           @id @default(autoincrement()) @map("id_elemento_contable")
  uuidElementoContable         String                           @unique @map("uuid_elemento_contable") @db.VarChar(64)
  nombre                       String                           @db.VarChar(50)
  disponible                   Boolean                          @default(true)
  codigoNumerico               Int                              @map("codigo_numerico")
  idNaturaleza                 BigInt                           @map("id_naturaleza")

  naturaleza                   DiccNaturalezaCuenta            @relation(fields: [idNaturaleza], references: [id])
  clasificacionesContables     ClasificacionElementoContable[]
  cuentasContables             CuentaContable[]
  subCuentasContables          SubCuentaContable[]

  @@unique([codigoNumerico])
  @@index([idNaturaleza])
  @@map("ELEMENTO_CONTABLE")
}

model ClasificacionElementoContable {
  id                           BigInt               @id @default(autoincrement()) @map("id_clasificacion_elemento_contable")
  uuidClasificacionContable    String               @unique @map("uuid_clasificacion_contable") @db.VarChar(64)
  nombre                       String               @db.VarChar(50)
  disponible                   Boolean              @default(true)
  codigoNumerico               Int                  @map("codigo_numerico")
  uuidElementoContable         String               @map("uuid_elemento_contable") @db.VarChar(64)

  elementoContable             ElementoContable     @relation(fields: [uuidElementoContable], references: [uuidElementoContable])
  cuentasContables             CuentaContable[]
  subCuentasContables          SubCuentaContable[]

  @@unique([uuidElementoContable, codigoNumerico])
  @@index([uuidElementoContable])
  @@map("CLASIFICACION_ELEMENTO_CONTABLE")
}

model CuentaContable {
  id                           BigInt                           @id @default(autoincrement()) @map("id_cuenta_contable")
  uuidCuentaContable           String                           @unique @map("uuid_cuenta_contable") @db.VarChar(64)
  nombre                       String                           @db.VarChar(50)
  disponible                   Boolean                          @default(true)
  uuidElementoContable         String                           @map("uuid_elemento_contable") @db.VarChar(64)
  uuidClasificacionContable    String                           @map("uuid_clasificacion_contable") @db.VarChar(64)
  codigoNumerico               Int                              @map("codigo_numerico")

  elementoContable             ElementoContable                 @relation(fields: [uuidElementoContable], references: [uuidElementoContable])
  clasificacionContable        ClasificacionElementoContable    @relation(fields: [uuidClasificacionContable], references: [uuidClasificacionContable])
  subCuentasContables          SubCuentaContable[]

  @@unique([uuidClasificacionContable, codigoNumerico])
  @@index([uuidElementoContable])
  @@index([uuidClasificacionContable])
  @@map("CUENTA_CONTABLE")
}

model SubCuentaContable {
  id                           BigInt                           @id @default(autoincrement()) @map("id_sub_cuenta_contable")
  uuidSubCuentaContable        String                           @unique @map("uuid_sub_cuenta_contable") @db.VarChar(64)
  nombre                       String                           @db.VarChar(50)
  disponible                   Boolean                          @default(true)
  uuidElementoContable         String                           @map("uuid_elemento_contable") @db.VarChar(64)
  uuidClasificacionContable    String                           @map("uuid_clasificacion_contable") @db.VarChar(64)
  uuidCuentaContable           String                           @map("uuid_cuenta_contable") @db.VarChar(64)
  codigoNumerico               Int                              @map("codigo_numerico")
  idNaturaleza                 BigInt                           @map("id_naturaleza")

  elementoContable             ElementoContable                 @relation(fields: [uuidElementoContable], references: [uuidElementoContable])
  clasificacionContable        ClasificacionElementoContable    @relation(fields: [uuidClasificacionContable], references: [uuidClasificacionContable])
  cuentaContable               CuentaContable                   @relation(fields: [uuidCuentaContable], references: [uuidCuentaContable])
  naturaleza                   DiccNaturalezaCuenta            @relation(fields: [idNaturaleza], references: [id])

  @@unique([uuidCuentaContable, codigoNumerico])
  @@index([uuidElementoContable])
  @@index([uuidClasificacionContable])
  @@index([uuidCuentaContable])
  @@index([idNaturaleza])
  @@map("SUB_CUENTA_CONTABLE")
}

enum EstadoUsuario {
  activo
  inactivo
}

enum EstadoProducto {
  activo
  inactivo
}

enum EstadoVenta {
  completada
  anulada
}

enum TipoMovimientoInventario {
  entrada
  salida
}

enum MetodoValuacion {
  FIFO
  PROMEDIO_PONDERADO
}

enum SubtipoEntradaInventario {
  PRODUCTO_NUEVO
  REABASTECIMIENTO
}

enum MotivoSalidaInventario {
  VENTA
  DANIO
  CONSUMO_INTERNO
  AJUSTE
  OTRO
}
