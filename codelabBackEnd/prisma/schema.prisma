generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Rol {
  id          BigInt       @id @default(autoincrement())
  nombre      String       @unique @db.VarChar(100)
  descripcion String?      @db.VarChar(255)
  disponible  Boolean      @default(true)
  createdAt   DateTime?    @map("created_at")
  rolPermisos RolPermiso[]
  usuarios    Usuario[]
}

model Permiso {
  id          BigInt           @id @default(autoincrement())
  nombre      String           @unique @db.VarChar(100)
  descripcion String?          @db.VarChar(255)
  disponible  Boolean          @default(true)
  createdAt   DateTime?        @map("created_at")
  categoriaId BigInt
  categoria   CategoriaPermiso @relation(fields: [categoriaId], references: [id])
  rolPermisos RolPermiso[]
}

model RolPermiso {
  rolId     BigInt
  permisoId BigInt
  permiso   Permiso @relation(fields: [permisoId], references: [id])
  rol       Rol     @relation(fields: [rolId], references: [id])

  @@id([rolId, permisoId])
}

model CategoriaPermiso {
  id              BigInt    @id @default(autoincrement())
  nombreCategoria String    @db.VarChar(150)
  disponible      Boolean   @default(true)
  permisos        Permiso[]
}

model Sucursal {
  id        BigInt   @id @default(autoincrement())
  nombre    String   @db.VarChar(150)
  direccion String?  @db.VarChar(255)
  telefono  String?  @db.VarChar(50)
  gerente   String?  @db.VarChar(150)
  activa    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt

  usuarios              Usuario[]
  inventarios           Inventario[]
  ventas                Venta[]
  establecimientos      Establecimiento[]
  movimientosInventario MovimientoInventario[]
  facturas              Factura[]
  alertasInventario     AlertaInventario[]
  periodosContables     PeriodoContable[]
}

model Usuario {
  id             BigInt        @id @default(autoincrement())
  nombreCompleto String        @map("nombre_completo") @db.VarChar(150)
  correo         String        @unique @db.VarChar(150)
  password       String        @db.VarChar(255)
  estado         EstadoUsuario @default(activo)
  createdAt      DateTime?     @map("created_at")
  updatedAt      DateTime?     @map("updated_at")
  sucursalId     BigInt?
  rolId          BigInt?
  eliminado      Boolean       @default(false)
  usuario        String        @unique @db.VarChar(100)
  rol            Rol?          @relation(fields: [rolId], references: [id])
  sucursal       Sucursal?     @relation(fields: [sucursalId], references: [id])
  ventas         Venta[]
  facturas       Factura[]
  movimientosInventario MovimientoInventario[]
  periodosCerrados PeriodoContable[] @relation("PeriodoContableUsuarioCierre")
}

model Categoria {
  id          BigInt     @id @default(autoincrement())
  nombre      String     @db.VarChar(150)
  descripcion String?    @db.VarChar(255)
  disponible  Boolean    @default(true)
  productos   Producto[]
}

model Proveedor {
  id                    BigInt                 @id @default(autoincrement())
  nombre                String                 @db.VarChar(150)
  telefono              String?                @db.VarChar(50)
  correo                String?                @db.VarChar(150)
  direccion             String?                @db.VarChar(255)
  disponible            Boolean                @default(true)
  productoProveedores   ProductoProveedor[]
  movimientosInventario MovimientoInventario[]
}

model Producto {
  id                  BigInt                 @id @default(autoincrement())
  nombre              String                 @db.VarChar(150)
  sku                 String                 @unique @db.VarChar(100)
  costo               Decimal                @db.Decimal(10, 2)
  precioVenta         Decimal                @map("precio_venta") @db.Decimal(10, 2)
  unidadMedida        String?                @map("unidad_medida") @db.VarChar(50)
  stockMinimo         Int                    @default(0) @map("stock_minimo")
  estado              EstadoProducto         @default(activo)
  createdAt           DateTime?              @default(now()) @map("created_at")
  updatedAt           DateTime?              @map("updated_at")
  categoriaId         BigInt?
  imagenUrl           String?                @map("imagen_url") @db.VarChar(255)
  imagenPath          String?                @map("imagen_path") @db.VarChar(255)
  categoria           Categoria?             @relation(fields: [categoriaId], references: [id])
  detalles            DetalleVenta[]
  inventarios         Inventario[]
  movimientos         MovimientoInventario[]
  productoProveedores ProductoProveedor[]
  alertasInventario   AlertaInventario[]
  detallesFactura DetalleFactura[]
  impuestoId BigInt?
  impuesto   Impuesto? @relation(fields: [impuestoId], references: [id])
}

model ProductoProveedor {
  productoId  BigInt
  proveedorId BigInt
  producto    Producto  @relation(fields: [productoId], references: [id], onDelete: Cascade)
  proveedor   Proveedor @relation(fields: [proveedorId], references: [id], onDelete: Cascade)

  @@id([productoId, proveedorId])
  @@index([proveedorId])
  @@map("producto_proveedor")
}

model Inventario {
  id          BigInt   @id @default(autoincrement())
  stockActual Int      @default(0) @map("stock_actual")
  productoId  BigInt
  sucursalId  BigInt
  producto    Producto @relation(fields: [productoId], references: [id])
  sucursal    Sucursal @relation(fields: [sucursalId], references: [id])
  alertas     AlertaInventario[]

  @@unique([productoId, sucursalId])
}

model AlertaInventario {
  id              BigInt   @id @default(autoincrement())
  productoId       BigInt   @map("producto_id")
  inventarioId     BigInt   @map("inventario_id")
  sucursalId       BigInt   @map("sucursal_id")
  stockActual      Int      @map("stock_actual")
  stockMinimo      Int      @map("stock_minimo")
  activa           Boolean  @default(true)
  mensaje          String   @db.VarChar(255)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  resueltaAt       DateTime? @map("resuelta_at")
  producto         Producto @relation(fields: [productoId], references: [id])
  inventario       Inventario @relation(fields: [inventarioId], references: [id])
  sucursal         Sucursal @relation(fields: [sucursalId], references: [id])

  @@unique([inventarioId])
  @@index([activa])
  @@index([productoId])
  @@index([sucursalId])
  @@map("alertas_inventario")
}

model MovimientoInventario {
  id                      BigInt                    @id @default(autoincrement())
  tipo                    TipoMovimientoInventario
  cantidad                Int
  referenciaTipo          String?                   @map("referencia_tipo") @db.VarChar(50)
  referenciaId            BigInt?                   @map("referencia_id")
  createdAt               DateTime                  @default(now()) @map("created_at")
  productoId              BigInt
  sucursalId              BigInt
  usuarioId               BigInt?
  proveedorId             BigInt?
  detalleMotivo           String?                   @map("detalle_motivo") @db.VarChar(255)
  estado                  String                    @default("completado") @db.VarChar(30)
  fechaMovimiento         DateTime                  @default(now()) @map("fecha_movimiento")
  motivoSalida            MotivoSalidaInventario?   @map("motivo_salida")
  observaciones           String?
  stockResultante         Int                       @map("stock_resultante")
  subtipoEntrada          SubtipoEntradaInventario? @map("subtipo_entrada")
  metodoValuacionAplicado MetodoValuacion?          @map("metodo_valuacion_aplicado")
  costoUnitario           Decimal?                  @map("costo_unitario") @db.Decimal(10, 2)
  costoTotal              Decimal?                  @map("costo_total") @db.Decimal(12, 2)
  asientoContableId       BigInt?                   @map("id_asiento_contable")

  producto                Producto                  @relation(fields: [productoId], references: [id])
  sucursal                Sucursal                  @relation(fields: [sucursalId], references: [id])
  usuario                 Usuario?                  @relation(fields: [usuarioId], references: [id])
  proveedor               Proveedor?                @relation(fields: [proveedorId], references: [id])
  asientoContable         AsientoContable?          @relation(fields: [asientoContableId], references: [id])

  @@index([fechaMovimiento])
  @@index([productoId])
  @@index([proveedorId])
  @@index([sucursalId])
  @@index([usuarioId])
}

model TipoCliente {
  id              BigInt    @id @default(autoincrement())
  nombre          String    @db.VarChar(200)
  descripcion     String?   @db.VarChar(255)
  condicionPago   String?   @map("condicion_pago") @db.VarChar(100)
  diasCredito     Int       @default(0) @map("dias_credito")
  disponible      Boolean   @default(true)
  fechaCreacion   DateTime  @default(now()) @map("fecha_creacion")
  clientes        Cliente[]
}

model Cliente {
  id             BigInt       @id @default(autoincrement())
  nombreCompleto String?      @map("nombre_completo") @db.VarChar(150)
  identificacion String?      @unique @db.VarChar(50)
  telefono       String?      @db.VarChar(50)
  correo         String?      @db.VarChar(150)
  direccion      String?      @db.VarChar(255)
  tipoClienteId  BigInt       
  tipoCliente    TipoCliente  @relation(fields: [tipoClienteId], references: [id])
  ventas         Venta[]
  facturas       Factura[]
}

model TipoDocumento {
  id                        BigInt                         @id @default(autoincrement()) @map("id_tipo_documento")
  numero                    Int                            @unique
  nombre                    String                         @unique @db.VarChar(150)
  descripcion               String?                        @db.VarChar(255)
  disponible                Boolean                        @default(true)
  createdAt                 DateTime                       @default(now()) @map("created_at")
  updatedAt                 DateTime                       @default(now()) @updatedAt @map("updated_at")
  cais                      Cai[]
  establecimientoDocumentos EstablecimientoTipoDocumento[]

  @@map("TiposDocumentos")
}


model RangoEmision {
  id           BigInt        @id @default(autoincrement()) @map("id_rango_emision")
  inicioRango  BigInt        @map("inicio_rango")
  finRango     BigInt        @map("final_rango")
  caiId        BigInt        @unique @map("id_cai")
  cai          Cai           @relation(fields: [caiId], references: [id])
  puntosEmision PuntoEmision[]

  @@map("RangoEmision")
}

model PuntoEmision {
  id                           BigInt                       @id @default(autoincrement()) @map("id_punto_emision")
  numero                       Int
  tipoDocumentoId              BigInt                       @map("id_tipo_documento")
  establecimientoId            BigInt                       @map("id_establecimiento")
  rangoEmisionId               BigInt                       @map("id_rango_emision")
  disponible                   Boolean
  rangoEmision                 RangoEmision                 @relation(fields: [rangoEmisionId], references: [id])
  establecimientoTipoDocumento EstablecimientoTipoDocumento @relation(fields: [establecimientoId, tipoDocumentoId], references: [establecimientoId, tipoDocumentoId])
  numerosFactura               NumeroFactura[]

  @@unique([tipoDocumentoId, establecimientoId, id])
  @@unique([numero, establecimientoId, tipoDocumentoId])
  @@map("PuntosEmision")
}

model Cai {
  id             BigInt           @id @default(autoincrement()) @map("id_cai")
  codigo         String           @unique @db.VarChar(100)
  fechaInicio    DateTime         @map("fecha_inicio")
  fechaFin       DateTime         @map("fecha_fin")
  activo         Boolean
  tipoDocumentoId BigInt          @default(1) @map("id_tipo_documento")
  tipoDocumento  TipoDocumento    @relation(fields: [tipoDocumentoId], references: [id])
  rangoEmision   RangoEmision?
  numerosFactura NumeroFactura[]

  @@map("Cai")
}

model NumeroFactura {
  id                BigInt       @id @default(autoincrement())
  numeroFormateado  String?      @unique @map("numero_formateado") @db.VarChar(50)
  correlativo       Int          
  establecimientoId BigInt       @map("id_establecimiento")
  puntoEmisionId    BigInt       @map("id_punto_emision")
  tipoDocumentoId   BigInt       @map("id_tipo_documento")
  caiId             BigInt       @map("id_cai")
  cai               Cai          @relation(fields: [caiId], references: [id])
  puntoEmision      PuntoEmision @relation(fields: [tipoDocumentoId, establecimientoId, puntoEmisionId], references: [tipoDocumentoId, establecimientoId, id])
  factura           Factura?

  @@unique([tipoDocumentoId, establecimientoId, puntoEmisionId, caiId, correlativo])
}
model Impuesto {
  id     BigInt  @id @default(autoincrement())
  nombre String
  tasa   Decimal @db.Decimal(5,2)
  activo Boolean @default(true)

  productos Producto[]
}
model Venta {
  id                BigInt              @id @default(autoincrement())
  total             Decimal             @db.Decimal(10, 2)
  estado            EstadoVenta
  createdAt         DateTime?           @default(now())

  clienteId         BigInt?
  usuarioId         BigInt?
  sucursalId        BigInt?
  asientoContableId BigInt?             @map("id_asiento_contable")

  cliente             Cliente?          @relation(fields: [clienteId], references: [id])
  usuario             Usuario?          @relation(fields: [usuarioId], references: [id])
  sucursal            Sucursal?         @relation(fields: [sucursalId], references: [id])
  asientoContable     AsientoContable?  @relation(fields: [asientoContableId], references: [id])
  

  detalles DetalleVenta[]
  factura  Factura?
}

model DetalleVenta {
  id             BigInt  @id @default(autoincrement())
  cantidad       Int
  precioUnitario Decimal @map("precio_unitario") @db.Decimal(10, 2)
  subtotal       Decimal @db.Decimal(10, 2)

  ventaId    BigInt
  productoId BigInt

  venta    Venta    @relation(fields: [ventaId], references: [id])
  producto Producto @relation(fields: [productoId], references: [id])
}

model Factura {
  id               BigInt         @id @default(autoincrement())
  subtotal         Decimal        @db.Decimal(10, 2)
  impuesto         Decimal        @db.Decimal(10, 2)
  total            Decimal        @db.Decimal(10, 2)

 
  importeExento     Decimal       @db.Decimal(10, 2) @default(0)
  importeGravado15  Decimal       @db.Decimal(10, 2) @default(0)
  importeGravado18  Decimal       @db.Decimal(10, 2) @default(0)

  isv15             Decimal       @db.Decimal(10, 2) @default(0)
  isv18             Decimal       @db.Decimal(10, 2) @default(0)

  fechaEmision     DateTime?      @map("fecha_emision")
  numeroFormateado String?        @unique @map("numero_formateado") @db.VarChar(50)

  ventaId           BigInt?       @unique
  clienteId         BigInt?
  usuarioId         BigInt?
  sucursalId        BigInt?
  asientoContableId BigInt?       @map("id_asiento_contable")

  asientoContable  AsientoContable? @relation(fields: [asientoContableId], references: [id])
  numeroFactura    NumeroFactura? @relation(fields: [numeroFormateado], references: [numeroFormateado])
  venta            Venta?         @relation(fields: [ventaId], references: [id])
  cliente          Cliente?       @relation(fields: [clienteId], references: [id])
  usuario          Usuario?       @relation(fields: [usuarioId], references: [id])
  sucursal         Sucursal?      @relation(fields: [sucursalId], references: [id])

  detalles DetalleFactura[]

  @@map("Facturas")
}
model DetalleFactura {
  id             BigInt  @id @default(autoincrement())
  facturaId      BigInt
  productoId     BigInt
  cantidad       Int
  precioUnitario Decimal @db.Decimal(10,2)
  subtotal       Decimal @db.Decimal(10,2)

  tasaImpuesto   Decimal @db.Decimal(5,2)
  montoImpuesto  Decimal @db.Decimal(10,2)
  tipoImpuesto   String

  factura  Factura  @relation(fields: [facturaId], references: [id])
  producto Producto @relation(fields: [productoId], references: [id])
}

model Establecimiento {
  id                        BigInt                         @id @default(autoincrement()) @map("id_establecimiento")
  numero                    Int
  nombre                    String                         @db.VarChar(150)
  sucursalId                BigInt
  disponible                Boolean                        @default(true)
  sucursal                  Sucursal                       @relation(fields: [sucursalId], references: [id])
  establecimientoDocumentos EstablecimientoTipoDocumento[]

  @@map("Establecimientos")
}

model EstablecimientoTipoDocumento {
  id                BigInt          @id @default(autoincrement()) @map("id_establecimiento_tipo_documento")
  establecimientoId BigInt          @map("id_establecimiento")
  tipoDocumentoId   BigInt          @map("id_tipo_documento")
  disponible        Boolean         @default(true)
  establecimiento   Establecimiento @relation(fields: [establecimientoId], references: [id])
  tipoDocumento     TipoDocumento   @relation(fields: [tipoDocumentoId], references: [id])
  puntosEmision     PuntoEmision[]

  @@unique([establecimientoId, tipoDocumentoId])
  @@map("establecimiento_tipo_documeto")
}

model ConfiguracionSistema {
  id                        BigInt          @id @default(autoincrement())
  metodoValuacionInventario MetodoValuacion @map("metodo_valuacion_inventario")
  monedaFuncional           String          @map("moneda_funcional") @db.VarChar(10)

  @@map("configuracion_sistema")
}


model PeriodoContable {
  id             BigInt                @id @default(autoincrement())
  sucursalId     BigInt                @map("sucursal_id")
  fechaInicio    DateTime              @map("fecha_inicio")
  fechaFin       DateTime              @map("fecha_fin")
  estado         EstadoPeriodoContable @default(ABIERTO)
  fechaCierre    DateTime?             @map("fecha_cierre")
  usuarioCierreId BigInt?              @map("usuario_cierre")
  createdAt      DateTime              @default(now()) @map("created_at")
  sucursal       Sucursal              @relation(fields: [sucursalId], references: [id])
  usuarioCierre  Usuario?              @relation("PeriodoContableUsuarioCierre", fields: [usuarioCierreId], references: [id])

  @@index([sucursalId])
  @@index([estado])
  @@index([sucursalId, fechaInicio, fechaFin])

  @@map("periodo_contable")
}

model AsientoContable {
  id                  BigInt   @id @default(autoincrement()) @map("id_asiento_contable")
  uuidAsientoContable String   @unique @map("uuid_asiento_contable") @db.VarChar(64)
  numeroAsiento       String   @unique @map("numero_asiento") @db.VarChar(100)
  descripcion         String?  @map("descripcion") @db.VarChar(255)
  tipoOperacion       EnumTipoOperacionContable @map("tipo_operacion")
  idOperacionOrigen   BigInt?  @map("id_operacion_origen")
  totalDebe           Decimal  @map("total_debe") @db.Decimal(14,2)
  totalHaber          Decimal  @map("total_haber") @db.Decimal(14,2)
  balanceado          Boolean  @map("balanceado")
  fecha               DateTime @default(now()) @map("fecha")

  detalles            DetalleAsientoContable[]

  ventas                Venta[]
  facturas              Factura[]
  movimientosInventario MovimientoInventario[]

  @@index([tipoOperacion])
  @@map("ASIENTOS_CONTABLES")
}

model DetalleAsientoContable {
  id                     BigInt  @id @default(autoincrement()) @map("id_detalle_asiento_contable")
  uuidDetalle            String  @unique @map("uuid_detalle") @db.VarChar(64)
  asientoId              BigInt  @map("id_asiento_contable")
  subCuentaContableId    BigInt  @map("id_sub_cuenta_contable")
  montoDebe              Decimal @map("monto_debe") @db.Decimal(14,2) @default(0)
  montoHaber             Decimal @map("monto_haber") @db.Decimal(14,2) @default(0)
  descripcion            String? @map("descripcion") @db.Text
  orden                  Int     @map("orden")

  asiento                AsientoContable @relation(fields: [asientoId], references: [id])
  subCuentaContable      SubCuentaContable @relation(fields: [subCuentaContableId], references: [id])

  @@index([asientoId])
  @@index([subCuentaContableId])

  @@map("DETALLE_ASIENTOS_CONTABLES")
}

model ReglaContable {
  id                 BigInt  @id @default(autoincrement()) @map("id_regla")
  tipoOperacion      EnumTipoOperacionContable @map("tipo_operacion")
  descripcion        String? @map("descripcion") @db.VarChar(100)
  subCuentaDebeId    BigInt  @map("subcuenta_debe")
  subCuentaHaberId   BigInt  @map("subcuenta_haber")
  subCuentaImpuestoId BigInt? @map("subcuenta_impuesto")
  disponible         Boolean @default(true) @map("disponible")

  subCuentaDebe      SubCuentaContable @relation("ReglaDebe", fields: [subCuentaDebeId], references: [id])
  subCuentaHaber     SubCuentaContable @relation("ReglaHaber", fields: [subCuentaHaberId], references: [id])
  subCuentaImpuesto  SubCuentaContable? @relation("ReglaImpuesto", fields: [subCuentaImpuestoId], references: [id])

  @@index([tipoOperacion])

  @@map("REGLAS_CONTABLES")
}

model DiccNaturalezaCuenta {
  id                  BigInt               @id @default(autoincrement()) @map("id_naturaleza")
  uuidNaturaleza      String               @unique @map("uuid_naturaleza") @db.VarChar(64)
  nombre              String               @db.VarChar(50)
  codigo              String               @unique
  disponible          Boolean              @default(true)

  elementosContables  ElementoContable[]
  subCuentasContables SubCuentaContable[]

  @@map("DICC_NATURALEZA_CUENTA")
}

model ElementoContable {
  id                           BigInt                           @id @default(autoincrement()) @map("id_elemento_contable")
  uuidElementoContable         String                           @unique @map("uuid_elemento_contable") @db.VarChar(64)
  nombre                       String                           @db.VarChar(50)
  disponible                   Boolean                          @default(true)
  codigoNumerico               Int                              @map("codigo_numerico")
  idNaturaleza                 BigInt                           @map("id_naturaleza")

  naturaleza                   DiccNaturalezaCuenta            @relation(fields: [idNaturaleza], references: [id])
  clasificacionesContables     ClasificacionElementoContable[]
  cuentasContables             CuentaContable[]
  subCuentasContables          SubCuentaContable[]

  @@unique([codigoNumerico])
  @@index([idNaturaleza])
  @@map("ELEMENTO_CONTABLE")
}

model ClasificacionElementoContable {
  id                           BigInt               @id @default(autoincrement()) @map("id_clasificacion_elemento_contable")
  uuidClasificacionContable    String               @unique @map("uuid_clasificacion_contable") @db.VarChar(64)
  nombre                       String               @db.VarChar(50)
  disponible                   Boolean              @default(true)
  codigoNumerico               Int                  @map("codigo_numerico")
  uuidElementoContable         String               @map("uuid_elemento_contable") @db.VarChar(64)

  elementoContable             ElementoContable     @relation(fields: [uuidElementoContable], references: [uuidElementoContable])
  cuentasContables             CuentaContable[]
  subCuentasContables          SubCuentaContable[]

  @@unique([uuidElementoContable, codigoNumerico])
  @@index([uuidElementoContable])
  @@map("CLASIFICACION_ELEMENTO_CONTABLE")
}

model CuentaContable {
  id                           BigInt                           @id @default(autoincrement()) @map("id_cuenta_contable")
  uuidCuentaContable           String                           @unique @map("uuid_cuenta_contable") @db.VarChar(64)
  nombre                       String                           @db.VarChar(50)
  disponible                   Boolean                          @default(true)
  uuidElementoContable         String                           @map("uuid_elemento_contable") @db.VarChar(64)
  uuidClasificacionContable    String                           @map("uuid_clasificacion_contable") @db.VarChar(64)
  codigoNumerico               Int                              @unique @map("codigo_numerico")
  idNaturaleza                 BigInt                           @map("id_naturaleza")
  elementoContable             ElementoContable                 @relation(fields: [uuidElementoContable], references: [uuidElementoContable])
  clasificacionContable        ClasificacionElementoContable    @relation(fields: [uuidClasificacionContable], references: [uuidClasificacionContable])
  subCuentasContables          SubCuentaContable[]

  @@unique([uuidClasificacionContable, codigoNumerico])
  @@index([uuidElementoContable])
  @@index([uuidClasificacionContable])
  @@map("CUENTA_CONTABLE")
}

model SubCuentaContable {

  id                           BigInt @id @default(autoincrement()) @map("id_sub_cuenta_contable")
  uuidSubCuentaContable        String @unique @map("uuid_sub_cuenta_contable") @db.VarChar(64)
  nombre                       String @db.VarChar(50)
  disponible                   Boolean @default(true)

  uuidElementoContable         String @map("uuid_elemento_contable") @db.VarChar(64)
  uuidClasificacionContable    String @map("uuid_clasificacion_contable") @db.VarChar(64)
  uuidCuentaContable           String @map("uuid_cuenta_contable") @db.VarChar(64)

  codigoNumerico               Int @map("codigo_numerico")
  idNaturaleza                 BigInt @map("id_naturaleza")

  elementoContable             ElementoContable @relation(fields: [uuidElementoContable], references: [uuidElementoContable])

  clasificacionContable        ClasificacionElementoContable @relation(fields: [uuidClasificacionContable], references: [uuidClasificacionContable])

  cuentaContable               CuentaContable @relation(fields: [uuidCuentaContable], references: [uuidCuentaContable])

  naturaleza                   DiccNaturalezaCuenta @relation(fields: [idNaturaleza], references: [id])

  detallesAsiento   DetalleAsientoContable[]

  reglasDebe        ReglaContable[] @relation("ReglaDebe")
  reglasHaber       ReglaContable[] @relation("ReglaHaber")
  reglasImpuesto    ReglaContable[] @relation("ReglaImpuesto")

  @@unique([uuidCuentaContable, codigoNumerico])
  @@index([uuidElementoContable])
  @@index([uuidClasificacionContable])
  @@index([uuidCuentaContable])
  @@index([idNaturaleza])

  @@map("SUB_CUENTA_CONTABLE")
}

